<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/doas2"
        android:label="@string/app_name"
        android:roundIcon="@drawable/doas2"
        android:supportsRtl="true"
        android:theme="@style/Theme.Doas">
        <activity
            android:name=".view.ProfileActivity"
            android:exported="false" />
        <activity
            android:name=".view.DetailLog"
            android:exported="false" />
        <activity
            android:name=".view.AbsenPulang"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity
            android:name=".helper.PreviewFotoActivity"
            android:exported="false" />
        <activity
            android:name=".view.Doas"
            android:exported="false" />
        <activity
            android:name=".view.PdfViewerActivity"
            android:exported="false" />
        <activity
            android:name=".view.Berita"
            android:exported="false" />
        <activity
            android:name=".view.BeritaDetailActivity"
            android:exported="false" />
        <activity
            android:name=".view.History"
            android:exported="false" />
        <activity
            android:name=".view.AbsenBko"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity
            android:name=".view.AbsenSakit"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity
            android:name=".view.AbsenDik"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity
            android:name=".view.Statuses"
            android:exported="false" />
        <activity
            android:name=".view.AbsenHadir"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity
            android:name=".view.AbsenCuti"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity
            android:name=".view.Home"
            android:exported="false" />
        <activity
            android:name=".Loginpage"
            android:exported="false" />
        <activity
            android:name=".view.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
