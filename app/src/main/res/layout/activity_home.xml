<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8"
    tools:context=".view.Home">

    <!-- ================= HERO HEADER ================= -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="300dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- VIEWPAGER -->
        <androidx.viewpager.widget.ViewPager
            android:id="@+id/pager"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- GRADIENT OVERLAY -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/hero_gradient"
            android:clickable="false"
            android:focusable="false"
            android:importantForAccessibility="no"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- LOGO -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="60dp"
            android:layout_margin="16dp"
            android:scaleType="fitXY"
            android:src="@drawable/doas2"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- HERO TEXT -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/tvJudul"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="D.O.A.S"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvIsi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DITTIPIDTER BARESKRIM"
                android:textColor="#E5E7EB"
                android:textSize="12sp"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ================= TAB MENU ================= -->
    <LinearLayout
        android:id="@+id/tbMenu"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:weightSum="5"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:layout_width="0dp"
            id="@+id/btAbsen"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#E2E8F0"
            android:text="Absen"
            android:textColor="#0C1F91"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btStatus"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Status"
            android:textSize="12sp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btInfo"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Berita"
            android:textSize="12sp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btLog"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Log"
            android:textSize="12sp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btDoas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="DOAS"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- ================= CONTENT ================= -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/resrkimwater"
        app:layout_constraintTop_toBottomOf="@id/tbMenu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Presensi Hari Ini"
                        android:textColor="#475569"
                        android:textSize="13sp"/>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btHadir"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/button_primary_ripple"
                        android:text="ABSEN DINAS LUAR"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="Menu Lainnya"
                android:textColor="#0F172A"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:useDefaultMargins="true">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btDik"
                    style="@style/MenuButtonSecondary"
                    android:text="DIK"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btCUti"
                    style="@style/MenuButtonSecondary"
                    android:text="Cuti"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btSakit"
                    style="@style/MenuButtonSecondary"
                    android:text="Sakit"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btBko"
                    style="@style/MenuButtonSecondary"
                    android:text="BKO"/>

            </GridLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="32dp"/>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
