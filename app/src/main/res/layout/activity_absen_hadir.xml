<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".view.AbsenHadir">

    <!-- OVERLAY -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#DE1A6608" />

    <!-- SCROLL CONTENT -->
    <ScrollView
        android:layout_marginTop="30dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvDisclaimer">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:fitsSystemWindows="true">

            <!-- HEADER -->
            <LinearLayout
                android:id="@+id/headerStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="#CC8EA27F"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/presence_online"
                    app:tint="#4CAF50" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Silahkan Ambil 2 foto untuk absensi"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/layoutGpsStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="10dp"
                android:layout_marginTop="8dp"
                android:background="#CC000000"
                app:layout_constraintTop_toBottomOf="@id/headerStatus"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/imgGpsStatus"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/presence_away"
                    app:tint="#FFC107"/>

                <TextView
                    android:id="@+id/tvGpsStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Mencari posisi anda Saat ini mohon menunggu......"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- CARD CAMERA -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCamera"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#FFFFFF"
                app:layout_constraintTop_toBottomOf="@id/layoutGpsStatus"
                app:layout_constraintDimensionRatio="4:5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.camera.view.PreviewView
                        android:id="@+id/ivFoto"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/black"/>


                    <ImageView
                        android:id="@+id/ivResult"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/camera_placeholder"
                        android:scaleType="centerCrop"
                        android:visibility="visible" />
                    <!-- TARUH PALING BAWAH -->
                    <TextView
                        android:id="@+id/tvLiveTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:padding="6dp"
                        android:background="#66000000"
                        android:layout_margin="12dp"/>

                </FrameLayout>

            </androidx.cardview.widget.CardView>

            <!-- SWITCH CAMERA BUTTON -->
            <ImageButton
                android:id="@+id/btnSwitch"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@android:color/transparent"
                android:elevation="12dp"
                android:scaleType="fitXY"
                android:src="@drawable/ic_switch_camera"
                android:layout_margin="12dp"
                app:tint="#640606"
                app:layout_constraintBottom_toBottomOf="@id/cardCamera"
                app:layout_constraintEnd_toEndOf="@id/cardCamera"/>

            <!-- THUMBNAIL AREA -->
            <LinearLayout
                android:id="@+id/layoutThumb"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="start|center_vertical"
                app:layout_constraintTop_toBottomOf="@id/cardCamera"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- LABEL ALASAN -->
            <TextView
                android:id="@+id/tvLabelAlasan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Jelaskan Alasan Anda Absen Dinas Luar"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/layoutThumb"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- INPUT ALASAN -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputLayoutAlasan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:boxBackgroundMode="outline"
                app:boxBackgroundColor="#FFFFFF"
                app:boxStrokeColor="#CCCCCC"
                app:hintTextAppearance="@style/HintFloatingStyle"
                app:layout_constraintTop_toBottomOf="@id/tvLabelAlasan"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAlasan"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:hint="Tuliskan alasan dinas luar..."
                    android:gravity="top|start"
                    android:textColor="#000000"
                    android:textColorHint="#888888"
                    android:padding="12dp"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:maxLines="6"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- BUTTON AREA -->
            <LinearLayout
                android:id="@+id/layoutButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:weightSum="2"
                app:layout_constraintTop_toBottomOf="@id/inputLayoutAlasan"
                app:layout_constraintBottom_toBottomOf="parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btMulai"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Mulai"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:backgroundTint="#E0E0E0"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btKirim"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Kirim"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2962FF"/>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- DISCLAIMER -->
    <TextView
        android:id="@+id/tvDisclaimer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:text="Foto diambil untuk keperluan audit internal, bukan untuk biometrik atau pencocokan wajah."
        android:textSize="15sp"
        android:textColor="#FBFBFB"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
