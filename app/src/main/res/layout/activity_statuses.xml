<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8"
    tools:context=".view.Home">

    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="300dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.viewpager.widget.ViewPager
            android:id="@+id/pager"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/hero_gradient"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageView
            android:layout_width="80dp"
            android:layout_height="60dp"
            android:layout_margin="16dp"
            android:scaleType="fitXY"
            android:src="@drawable/doas2"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/tvJudul"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="D.O.A.S"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvIsi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DITTIPIDTER BARESKRIM"
                android:textColor="#E5E7EB"
                android:textSize="12sp"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- TAB MENU -->
    <LinearLayout
        android:id="@+id/tbMenu"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:weightSum="5"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btAbsen"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Absen"
            android:textSize="12sp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btStatus"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:textColor="#0C1F91"
            android:text="Status"
            android:textStyle="bold"
            android:background="#E2E8F0"
            android:textSize="12sp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btInfo"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Berita"
            android:textSize="12sp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btLog"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Log"
            android:textSize="12sp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btDoas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="DOAS"
            android:textSize="12sp"/>
    </LinearLayout>


    <!-- SCROLL -->
    <ScrollView
        android:background="@drawable/resrkimwater"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tbMenu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:id="@+id/cardStatusHariIni"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp">

                <!-- TANGGAL -->
                <TextView
                    android:id="@+id/tvTanggal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01 Feb 2026"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#111827"/>
                <TextView
                    android:id="@+id/tvLabelJm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvTanggal"
                    android:layout_marginTop="10dp"
                    android:text="Jam Masuk"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:visibility="visible"/>
                <TextView
                    android:id="@+id/tvKet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HADIR"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#16A34A"
                    android:layout_alignParentEnd="true"/>
                <TextView
                    android:id="@+id/tvSubdit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Subdit 1"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#16A34A"
                    android:layout_below="@id/tvKet"
                    android:layout_alignParentEnd="true"/>


                <!-- JAM -->
                <TextView
                    android:id="@+id/tvJam"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvLabelJm"
                    android:layout_marginTop="6dp"
                    android:text="Masuk: 07:01"
                    android:textSize="12sp"
                    android:textColor="#475569"/>
                <TextView
                    android:id="@+id/tvLat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvJam"
                    android:layout_marginTop="6dp"
                    android:text="Latitude: -106.32321 | Longitude:6.35454"
                    android:textSize="12sp"
                    android:textColor="#475569"
                    android:visibility="visible"/>
                <TextView
                    android:id="@+id/tvAlamat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#666"
                    android:layout_below="@+id/tvLat"
                    android:visibility="gone"/>
                <!-- Foto Masuk -->
                <LinearLayout
                    android:layout_below="@id/tvAlamat"
                    android:id="@+id/layoutThumbMasuk"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">
                    <ImageView
                        android:id="@+id/imgFoto"
                        android:layout_width="80dp"
                        android:layout_height="match_parent"
                        android:background="@color/black"
                        android:scaleType="fitXY"
                        android:visibility="visible"/>
                    <ImageView
                        android:layout_marginStart="15dp"
                        android:id="@+id/imgFoto2"
                        android:layout_width="80dp"
                        android:layout_height="match_parent"
                        android:background="@color/black"
                        android:scaleType="fitXY"
                        android:visibility="visible"/>
                </LinearLayout>
                <!-- KETAM -->
                <TextView
                    android:id="@+id/tvLabelKR"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/layoutThumbMasuk"
                    android:layout_marginTop="10dp"
                    android:text="Keterangan Masuk"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:visibility="visible"/>

                <TextView
                    android:id="@+id/tvKetam"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvLabelKR"
                    android:layout_marginTop="4dp"
                    android:text="Sakit Batuk"
                    android:textSize="12sp"
                    android:textColor="#475569"
                    android:visibility="visible"/>
                <!-- RANGE -->
                <TextView
                    android:layout_marginTop="3dp"
                    android:layout_below="@+id/tvKetam"
                    android:id="@+id/pembatas"
                    android:background="#615757"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"/>
                <TextView
                    android:id="@+id/tvLabelR"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/pembatas"
                    android:layout_marginTop="10dp"
                    android:text="Jamp Pulang"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:visibility="visible"/>

                <TextView
                    android:id="@+id/tvPulang"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvLabelR"
                    android:layout_marginTop="4dp"
                    android:text="Pulang: -"
                    android:textSize="12sp"
                    android:textColor="#475569"
                    android:visibility="visible"/>
                <TextView
                    android:id="@+id/tvLatPulang"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvPulang"
                    android:layout_marginTop="6dp"
                    android:text="Latitude: -106.32321 | Longitude:6.35454"
                    android:textSize="12sp"
                    android:textColor="#475569"
                    android:visibility="visible"/>
                <TextView
                    android:id="@+id/tvAlamatPulang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#666"
                    android:layout_below="@+id/tvLatPulang"
                    android:visibility="gone"/>

                <!-- Foto PULANG -->
                <LinearLayout
                    android:layout_below="@id/tvAlamatPulang"
                    android:id="@+id/layoutThumbPulang"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">
                    <ImageView
                        android:id="@+id/imgFotoPulang"
                        android:layout_width="80dp"
                        android:layout_height="match_parent"
                        android:background="@color/black"
                        android:scaleType="fitXY"
                        android:visibility="visible"/>
                    <ImageView
                        android:layout_marginStart="15dp"
                        android:id="@+id/imgFotoPulang2"
                        android:layout_width="80dp"
                        android:layout_height="match_parent"
                        android:background="@color/black"
                        android:scaleType="fitXY"
                        android:visibility="visible"/>
                </LinearLayout>

                <!-- KETPUL -->
                <TextView
                    android:id="@+id/tvLabelKRP"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/layoutThumbPulang"
                    android:layout_marginTop="10dp"
                    android:text="Keterangan Pulang"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:visibility="visible"/>

                <TextView
                    android:id="@+id/tvKepul"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvLabelKRP"
                    android:layout_marginTop="4dp"
                    android:text="Sakit Batuk"
                    android:textSize="12sp"
                    android:textColor="#475569"
                    android:visibility="visible"/>




                <!-- BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPulang"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_below="@id/tvKepul"
                    android:layout_marginTop="12dp"
                    android:text="Absen Pulang"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2563EB"
                    android:visibility="visible"/>

            </RelativeLayout>

        </androidx.cardview.widget.CardView>
        </LinearLayout>

    </ScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>
