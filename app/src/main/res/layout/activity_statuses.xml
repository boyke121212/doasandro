<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app"
    tools:context=".view.Statuses">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="280dp"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="@color/brand_primary">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_collapseMode="parallax">

                <androidx.viewpager.widget.ViewPager
                    android:id="@+id/pager"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/hero_gradient" />
                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="40dp"
                    android:scaleType="fitStart"
                    android:src="@drawable/doas2"
                    android:layout_marginBottom="8dp"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:layout_margin="24dp"
                    android:orientation="vertical">

              ]
                    <TextView
                        android:id="@+id/tvJudul"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="D.O.A.S"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        app:fontFamily="sans-serif-black"/>

                    <TextView
                        android:id="@+id/tvIsi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DITTIPIDTER BARESKRIM POLRI"
                        android:textColor="#E5E7EB"
                        android:textSize="14sp"
                        android:letterSpacing="0.1"/>
                </LinearLayout>
            </FrameLayout>

            <androidx.appcompat.widget.Toolbar
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="-26dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:id="@+id/tbMenu"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:weightSum="6">

                <LinearLayout
                    android:id="@+id/btAbsen"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_fingerprint"
                        app:tint="@color/text_muted"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Absen"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnStatusNav"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@color/bg_tab_active">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_status"
                        app:tint="@color/brand_primary"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/brand_primary"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btInfo"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_news"
                        app:tint="@color/text_muted"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Berita"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btLog"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_log"
                        app:tint="@color/text_muted"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Log"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btProfile"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_person"
                        app:tint="@color/text_muted"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Profile"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"/>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/btDoas"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_about"
                        app:tint="@color/text_muted"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DOAS"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStatusHariIni"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/state_divider">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/tvTanggal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Senin, 01 Feb 2026"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            app:cardBackgroundColor="#E8F5E9"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp">
                            <TextView
                                android:id="@+id/tvKet"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:text="HADIR"
                                android:textColor="#2E7D32"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </com.google.android.material.card.MaterialCardView>
                    </RelativeLayout>

                    <TextView
                        android:id="@+id/tvSubdit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Subdit 1 - Tindak Pidana Tertentu"
                        android:textColor="@color/brand_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="20dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/state_divider"
                        android:layout_marginBottom="20dp"/>

                    <!-- MASUK SECTION -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <View
                            android:layout_width="4dp"
                            android:layout_height="40dp"
                            android:background="@color/brand_primary"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:id="@+id/tvLabelJm"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Absen Masuk"
                                android:textColor="@color/text_muted"
                                android:textSize="12sp" />
                            <TextView
                                android:id="@+id/tvJam"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="07:01 WIB"
                                android:textColor="@color/text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutThumbMasuk"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginBottom="12dp"
                        android:orientation="horizontal">
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="100dp"
                            android:layout_height="match_parent"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:id="@+id/imgFoto"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/camera_placeholder" />
                        </com.google.android.material.card.MaterialCardView>
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="100dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="12dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:id="@+id/imgFoto2"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/camera_placeholder" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvLabelKR"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Keterangan Masuk"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvKetam"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#F8FAFC"
                        android:padding="12dp"
                        android:text="Keterangan: Sakit Batuk"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="24dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/state_divider"
                        android:layout_marginBottom="24dp"/>

                    <!-- PULANG SECTION -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <View
                            android:layout_width="4dp"
                            android:layout_height="40dp"
                            android:background="#F59E0B"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:id="@+id/tvLabelR"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Absen Pulang"
                                android:textColor="@color/text_muted"
                                android:textSize="12sp" />
                            <TextView
                                android:id="@+id/tvPulang"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Belum Absen"
                                android:textColor="@color/text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutThumbPulang"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginBottom="12dp"
                        android:orientation="horizontal"
                        android:visibility="gone">
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="100dp"
                            android:layout_height="match_parent"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:id="@+id/imgFotoPulang"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop" />
                        </com.google.android.material.card.MaterialCardView>
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="100dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="12dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:id="@+id/imgFotoPulang2"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvLabelKRP"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Keterangan Pulang"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvKepul"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#F8FAFC"
                        android:padding="12dp"
                        android:text="Belum ada keterangan pulang"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp"
                        android:visibility="gone"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPulang"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="16dp"
                        android:text="Lakukan Absen Pulang"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:cornerRadius="14dp"
                        app:backgroundTint="@color/brand_primary"
                        app:icon="@drawable/ic_fingerprint"
                        app:iconGravity="textStart" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="20dp">
                        <TextView
                            android:id="@+id/tvLat"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Lokasi Masuk: -106.32321, 6.35454"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted" />
                        <TextView
                            android:id="@+id/tvAlamat"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Mencari alamat..."
                            android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginTop="4dp"
                            android:visibility="gone"/>
                        <TextView
                            android:id="@+id/tvLatPulang"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Lokasi Pulang: -"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginTop="8dp"/>
                        <TextView
                            android:id="@+id/tvAlamatPulang"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Mencari alamat..."
                            android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginTop="4dp"
                            android:visibility="gone"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
