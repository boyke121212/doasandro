<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Doas" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.Doas" parent="Base.Theme.Doas" />
    <style name="Theme.App" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">#2962FF</item>
        <item name="colorPrimaryVariant">#0039CB</item>
        <item name="colorOnPrimary">#FFFFFF</item>
    </style>

    <style name="LabelProfile">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#475569</item>
        <item name="android:layout_marginTop">12dp</item>
    </style>

    <style name="EditProfile">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/button_secondary</item>
        <item name="android:padding">12dp</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#1E293B</item>
    </style>

    <!-- INPUT PREMIUM -->
    <style name="InputLogin" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundMode">outline</item>
        <item name="boxStrokeColor">#2962FF</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxStrokeWidthFocused">2.5dp</item>
        <item name="boxBackgroundColor">#FFFFFF</item>
        <item name="hintTextColor">#666666</item>
    </style>
    <style name="ChipRadio">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:background">@drawable/bg_chip</item>
        <item name="android:button">@null</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#374151</item>
    </style>
    <style name="HintFloatingStyle" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">#666666</item>
        <item name="android:background">@color/white</item>
    </style>

    <style name="DatePickerTheme" parent="Theme.AppCompat.Light.Dialog">
        <item name="colorAccent">#0D47A1</item>
        <item name="android:textColorPrimary">#000000</item>
    </style>

    <style name="MenuButtonSecondary">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:background">@drawable/button_primary</item>
        <item name="android:textColor">#FFFCFC</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="MenuButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:background">@drawable/button_secondary</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/roboto</item>
    </style>

    <style name="TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="hintTextAppearance">@style/HintText</item>
        <item name="boxBackgroundMode">outline</item>
        <item name="android:textAppearance">?attr/textAppearanceCaption</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:layout_marginTop">10dp</item>
    </style>
    <style name="HintText" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="MyCustomTabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">10sp</item>
    </style>
</resources>
