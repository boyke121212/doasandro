<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background putih -->
    <solid android:color="#FFFFFF"/>

    <!-- Border halus -->
    <stroke
        android:width="1dp"
        android:color="#D0D0D0"/>

    <!-- Sudut membulat -->
    <corners android:radius="6dp"/>

    <!-- Padding internal -->
    <padding
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp"/>

</shape>
